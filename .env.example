# Variáveis de ambiente necessárias para rodar o projeto
# Copie este arquivo: cp .env.example .env
# e preencha com seus valores

# Porta do servidor (opcional, padrão: 3000)
PORT=3000

# String de conexão do MongoDB
# Opção 1 — MongoDB local via Docker (recomendado para dev):
MONGO_URI=mongodb://localhost:27017/order-db

# Opção 2 — MongoDB Atlas (cloud):
# MONGO_URI=mongodb+srv://<usuario>:<senha>@<cluster>.mongodb.net/order-db?retryWrites=true&w=majority

# Ambiente de execução (development | production)
NODE_ENV=development
